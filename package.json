{
  "name": "auto-scout-bot",
  "version": "0.1.0",
  "description": "24/7 Bot for finding value car deals across German auto platforms",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "tsx watch server/index.ts",
    "client:dev": "vite --config vite.config.ts",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc --project server/tsconfig.json || true",
    "build:client": "vite build --config vite.config.ts",
    "preview": "vite preview",
    "start": "node dist/server/index.js",
    "test": "vitest",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "prisma:studio": "prisma studio"
  },
  "keywords": [
    "auto",
    "scraper",
    "deals"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.8.0",
    "@tanstack/react-query": "^5.25.0",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "node-schedule": "^2.1.1",
    "nodemailer": "^6.9.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "tailwindcss": "^3.4.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "@types/node-schedule": "^2.1.5",
    "@types/nodemailer": "^6.4.14",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.32",
    "prisma": "^5.8.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vitest": "^1.0.4"
  }
}
